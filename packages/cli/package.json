{
  "name": "@mcpup/cli",
  "version": "0.1.1",
  "description": "One-shot semantic health check for MCP servers: catches silent failures and schema drift.",
  "type": "module",
  "license": "MIT",
  "author": "Mattis \"LayZ\"",
  "homepage": "https://github.com/sv-LayZ/mcpup#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sv-LayZ/mcpup.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/sv-LayZ/mcpup/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "monitoring",
    "health-check",
    "schema-drift",
    "observability",
    "cli",
    "uptime",
    "ai-agents"
  ],
  "bin": {
    "mcp-check": "dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "bun build ./src/bin.ts --target=node --outfile=dist/bin.js && chmod +x dist/bin.js",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@mcpup/core": "workspace:*",
    "typescript": "5.9.2"
  }
}
