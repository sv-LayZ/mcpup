{
  "name": "@mcpup/core",
  "version": "0.1.0",
  "description": "Semantic probe engine for MCP servers: handshake, strict validation, schema snapshot & drift.",
  "type": "module",
  "license": "MIT",
  "author": "Mattis \"LayZ\"",
  "homepage": "https://github.com/sv-LayZ/mcpup#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sv-LayZ/mcpup.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/sv-LayZ/mcpup/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "monitoring",
    "health-check",
    "schema-drift",
    "observability",
    "ai-agents"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "bun build ./src/index.ts --target=node --outdir=dist && tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0"
  },
  "devDependencies": {
    "typescript": "5.9.2",
    "zod": "4.4.3"
  }
}
